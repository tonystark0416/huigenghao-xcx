<!--pages/goods/goods.wxml-->
<navigation-bar title="商品详情" back="{{true}}" color="black" background="#FFF"></navigation-bar>

<view class="page">
  <block wx:if="{{loading}}">
    <view class="loading-container">
      <text class="loading-text">加载中...</text>
    </view>
  </block>

  <block wx:elif="{{goods}}">
    <scroll-view class="detail-scroll" scroll-y>
      <!-- 商品主图 -->
      <image class="goods-image" src="{{goods.image}}" mode="aspectFill"></image>

      <!-- 价格区域 -->
      <view class="price-section">
        <view class="price-row">
          <text class="price-symbol">¥</text>
          <text class="price-value">{{goods.price}}</text>
          <text wx:if="{{goods.originalPrice > goods.price}}" class="original-price">¥{{goods.originalPrice}}</text>
          <text wx:if="{{goods.discount}}" class="discount-tag">{{goods.discount * 10}}折</text>
        </view>

        <!-- 返利信息 -->
        <view class="rebate-row">
          <text class="rebate-label">预估返利</text>
          <text class="rebate-value">¥{{goods.rebate}}</text>
          <text wx:if="{{goods.rebateRate}}" class="rebate-rate">(返{{goods.rebateRate}}%)</text>
        </view>
      </view>

      <!-- 商品标题 -->
      <view class="info-section">
        <text class="goods-title">{{goods.title}}</text>
      </view>

      <!-- 标签 -->
      <view wx:if="{{goods.tags.length > 0}}" class="tags-row">
        <text wx:for="{{goods.tags}}" wx:key="*this" class="tag-item">{{item}}</text>
      </view>

      <!-- 店铺 & 分类 -->
      <view class="meta-section">
        <view wx:if="{{goods.brandName}}" class="meta-item">
          <text class="meta-label">品牌</text>
          <text class="meta-value">{{goods.brandName}}</text>
        </view>
        <view wx:if="{{goods.storeName}}" class="meta-item">
          <text class="meta-label">店铺</text>
          <text class="meta-value">{{goods.storeName}}</text>
        </view>
        <view wx:if="{{goods.categoryName}}" class="meta-item">
          <text class="meta-label">分类</text>
          <text class="meta-value">{{goods.categoryName}}</text>
        </view>
        <view wx:if="{{goods.sales}}" class="meta-item">
          <text class="meta-label">销量</text>
          <text class="meta-value">{{goods.sales}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar">
      <view class="bottom-rebate">
        <text class="bottom-rebate-label">返利</text>
        <text class="bottom-rebate-value">¥{{goods.rebate}}</text>
      </view>
      <button class="buy-btn" bindtap="onCopyLink">复制链接去购买</button>
    </view>
  </block>

  <block wx:else>
    <view class="loading-container">
      <text class="loading-text">商品信息获取失败</text>
    </view>
  </block>
</view>
