/**index.wxss**/

page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.page {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 顶部搜索栏 */
.search-bar {
  padding: 20rpx 24rpx;
  background: #fff;
}

.search-box {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  line-height: 1;
}

.search-placeholder {
  font-size: 28rpx;
  color: #bbb;
}

/* 主内容区 */
.main-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-tip {
  font-size: 26rpx;
  color: #ccc;
}
